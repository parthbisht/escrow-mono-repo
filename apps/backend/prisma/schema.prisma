generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EscrowState {
  Pending
  Delivered
  Disputed
  Resolved
  Cancelled
}

model Escrow {
  id           String      @id @default(uuid()) @db.Uuid
  escrowId     String      @unique
  buyer        String
  seller       String
  arbitrator   String
  amount       Decimal     @db.Decimal(38, 0)
  buyerAmount  Decimal?    @db.Decimal(38, 0)
  sellerAmount Decimal?    @db.Decimal(38, 0)
  state        EscrowState @default(Pending)
  metadata     String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([buyer])
  @@index([seller])
  @@index([arbitrator])
  @@index([state])
}

model ProcessedBlockchainEvent {
  id          String   @id @default(uuid()) @db.Uuid
  eventKey    String   @unique
  escrowId    String?
  eventName   String
  blockNumber BigInt
  txHash      String
  logIndex    Int
  createdAt   DateTime @default(now())

  @@index([escrowId])
  @@index([blockNumber])
}
