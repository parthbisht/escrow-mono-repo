{
  "name": "escrow-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/smart-contract",
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "dev:frontend": "npm run dev --workspace frontend-dapp",
    "dev:backend": "npm run start:dev --workspace escrow-backend",
    "dev:contracts": "npm run test --workspace escrow-contracts"
  }
}
